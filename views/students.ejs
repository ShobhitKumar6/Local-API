<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Data will be here</h2>

    <table border="1">
        <tr>
            <td>Name</td>
            <td>Age</td>
            <td>Email</td>
            <td>Delete</td>
            <td>update</td>
        </tr>
        <%students.forEach(student=>{ %>
            <tr>
                <td><%=student.name%></td>
                <td><%=student.age%></td>
                <td><%=student.email%></td>
                <td><a href="/ui/delete/<%= student._id%>">delete</a></td>
                <td><a href="/ui/student/<%= student._id%>">update</a></td>

            </tr>
            <% }) %>

    </table>
</body>

</html>